# ============================================================
# COPY THIS FILE TO .env AND FILL IN YOUR REAL VALUES
# NEVER commit .env to version control
# ============================================================

# ── Instagram / Meta ────────────────────────────────────────
# From https://developers.facebook.com/apps/ → your App → Settings → Basic
INSTAGRAM_APP_ID=your_meta_app_id_here
INSTAGRAM_APP_SECRET=your_meta_app_secret_here

# Long-lived Page Access Token (generated via Graph API Explorer)
# Requires permissions: instagram_basic, instagram_manage_comments,
#   instagram_manage_messages, pages_show_list, pages_read_engagement
INSTAGRAM_PAGE_ACCESS_TOKEN=your_long_lived_page_access_token_here

# Your Instagram Business/Creator Account ID
# GET https://graph.facebook.com/v20.0/me/accounts → find ig_id
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_ig_business_account_id_here

# Webhook verify token — any random string you choose
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=my_super_secret_verify_token_123

# ── TikTok ──────────────────────────────────────────────────
# From https://developers.tiktok.com/ → Manage Apps → your App
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here

# OAuth 2.0 access token (obtained after user authorisation flow)
# Scopes needed: user.info.basic, video.publish, video.upload,
#   research.adlib.basic (for analytics)
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here

# Your TikTok user open_id (returned during OAuth exchange)
TIKTOK_OPEN_ID=your_tiktok_open_id_here

# ── Bot behaviour ────────────────────────────────────────────
# Comma-separated keywords that trigger the auto-DM (case-insensitive)
TRIGGER_KEYWORDS=LINK,INFO,SEND

# Message sent to users who comment a trigger keyword
DM_MESSAGE=Hey! Thanks for your interest. Here is the link you asked for: https://your-link.com 🎉

# How many seconds to wait before retrying after a rate-limit (fallback)
RATE_LIMIT_RETRY_SECONDS=60

# Webhook server port
WEBHOOK_PORT=8000
